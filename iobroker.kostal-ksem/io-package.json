{
  "common": {
    "name": "kostal-ksem",
    "version": "0.2.0",
    "title": "KOSTAL Smart Energy Meter",
    "titleLang": { "en": "KOSTAL Smart Energy Meter", "de": "KOSTAL Smart Energy Meter" },
    "desc": {
      "en": "Adapter for KOSTAL Smart Energy Meter (KSEM) via WebSocket API",
      "de": "Adapter für KOSTAL Smart Energy Meter (KSEM) über WebSocket API"
    },
    "authors": ["Jan Pedder"],
    "license": "MIT",
    "platform": "Javascript/Node.js",
    "main": "main.js",
    "enabled": true,
    "mode": "daemon",
    "type": "energy",
    "connectionType": "local",
    "dataSource": "push",
    "loglevel": "info",
    "adminUI": { "config": "json" }
  },
  "native": {},
  "objects": [],
  "instanceObjects": [
    {
      "_id": "info",
      "type": "channel",
      "common": { "name": "Geräteinfo" },
      "native": {}
    },
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "name": "Verbunden",
        "type": "boolean",
        "role": "indicator.connected",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    }
  ]
}
